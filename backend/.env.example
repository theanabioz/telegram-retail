PORT=4000
FRONTEND_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

BOT_TOKEN=your-telegram-bot-token
# Enable only in the single production backend instance that owns Telegram getUpdates polling.
TELEGRAM_BOT_POLLING_ENABLED=false
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=7d
APP_TIME_ZONE=Europe/Lisbon
# Use true only for local/staging workflows. Production must be false.
DEV_AUTH_ENABLED=false
