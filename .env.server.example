APP_DOMAIN=retail-example.xyz
DB_DOMAIN=db.retail-example.xyz

PORT=4000
FRONTEND_ORIGIN=https://retail-example.xyz

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-me

BOT_TOKEN=replace-me
TELEGRAM_ALERT_CHAT_IDS=

JWT_SECRET=replace-with-very-long-random-secret
JWT_EXPIRES_IN=7d
APP_TIME_ZONE=Europe/Lisbon
DEV_AUTH_ENABLED=false

# Self-hosted Postgres.
POSTGRES_DB=telegram_retail
POSTGRES_USER=telegram_retail
POSTGRES_PASSWORD=replace-me
BACKUP_RETENTION_DAYS=7
BASEBACKUP_RETENTION_DAYS=7
WAL_RETENTION_DAYS=7

HEALTHCHECK_INTERVAL_MINUTES=5
DISK_ALERT_THRESHOLD_PERCENT=85
SSL_ALERT_THRESHOLD_DAYS=14
ALERT_STATE_DIR=/opt/telegram-retail/state/alerts

OFFSITE_BACKUP_ENABLED=false
OFFSITE_S3_ENDPOINT=
OFFSITE_S3_REGION=us-east-1
OFFSITE_S3_BUCKET=
OFFSITE_S3_PREFIX=telegram-retail
OFFSITE_AWS_ACCESS_KEY_ID=
OFFSITE_AWS_SECRET_ACCESS_KEY=

DB_BASIC_AUTH_USER=dbadmin
DB_BASIC_AUTH_PASSWORD_HASH=
CLOUDBEAVER_ADMIN_NAME=dbadmin
CLOUDBEAVER_ADMIN_PASSWORD=
